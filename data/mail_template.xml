<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="mail_template_ticket_state_change" model="mail.template">
            <field name="name">Helpdesk : notification changement de statut</field>
            <field name="model_id" ref="odoo_website_helpdesk.model_help_ticket"/>

            <field name="subject">
                [Ticket] {{ object.name }} - Passage au statut : {{ object.stage_id.name or '' }}
            </field>

            <field name="email_from">Workflow Helpdesk &lt;helpdesk@araymond.com&gt;</field>
            <field name="email_to"></field>

            <field name="body_html" type="html">
                <div>
                    Bonjour, <br/><br/>

                    Le ticket <strong><t t-out="object.name"/></strong>
                    vient de passer au statut :
                    <strong><t t-out="object.stage_id.name"/></strong>.
                    <br/><br/>

                    Action réalisée par : <strong><t t-out="user.name"/></strong>
                    <br/><br/>

                    <div>
                        <strong>Sujet :</strong>
                        <t t-out="object.subject or ''"/>
                    </div>

                    <div style="margin-top:8px;">
                        <strong>Description :</strong><br/>
                        <t t-out="object.description or ''"/>
                    </div>

                    <div style="margin-top:8px;">
                        <strong>Demandeur :</strong>
                        <t t-out="object.customer_id.name or object.customer_name or ''"/>
                    </div>

                    <!--  Afficher Assigné à seulement si Draft -->
                    <t t-if="(object.stage_id.name or '') == 'Draft' and object.assigned_user">
                        <div style="margin-top:8px;">
                            <strong>Assigné à :</strong>
                            <t t-out="object.assigned_user.name"/>
                        </div>
                    </t>

                    <div style="margin: 16px 0px 16px 0px;">
                        <a t-attf-href="/web#id=#{ object.id }&amp;model=help.ticket&amp;cids=1&amp;menu_id=350&amp;action=491&amp;view_type=form"
                           style="background-color: #1481f4; padding: 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                            Accéder au ticket
                        </a>
                    </div>

                    Merci,
                </div>
            </field>
        </record>

    </data>
</odoo>
